---
import '../styles/global.css';
import { projects } from '../lib/projects';
interface Props { title: string; scoped?: boolean; }
const { title, scoped = false } = Astro.props;
const nav = [
  { label: 'Projects', href: '/projects' },
  { label: 'Dashboard', href: '/' },
  { label: 'GTM Kanban', href: '/gtm' },
  { label: 'Keywords', href: '/seo/keywords' },
  { label: 'Competitors', href: '/seo/competitors' },
  { label: 'Google Ads', href: '/sem/ads' },
  { label: 'Click Report', href: '/sem/report' },
];
const current = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — BBG SEO & Ads</title>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Header -->
  <header class="border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/">
        <img
          src="/logo.svg"
          alt="Beyond Border Group"
          class="h-8 w-auto"
        />
      </a>
      <nav class="flex items-center gap-1">
        {nav.map(item => (
          <a
            href={item.href}
            class={`px-3 py-1.5 rounded text-sm font-medium transition-colors ${
              current === item.href
                ? 'text-white'
                : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'
            }`}
            style={current === item.href ? 'background: var(--bbg-gray-dark)' : ''}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Project context bar: the project is the top-level entry -->
    <div class="border-t border-gray-100" style="background: #fafafa">
      <div class="max-w-7xl mx-auto px-6 py-2.5 flex items-center gap-3">
        <span class="text-xs font-semibold uppercase tracking-widest" style="color: var(--bbg-gray-muted)">Project</span>
        <div class="relative">
          <span id="project-dot" class="absolute left-3 top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full" style="background: var(--bbg-gray-dark)"></span>
          <select
            id="project-select"
            class="appearance-none text-sm font-semibold rounded-lg border border-gray-200 bg-white pl-8 pr-9 py-1.5 cursor-pointer hover:border-gray-400 focus:outline-none focus:border-gray-500"
          >
            {projects.map(p => (
              <option value={p.id} data-color={p.color}>{p.name}</option>
            ))}
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </div>
        <a href="/projects" class="text-xs text-gray-400 hover:text-gray-600">Manage projects &rarr;</a>
      </div>
    </div>
  </header>

  <!-- Page -->
  <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-10">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-200 mt-auto">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center text-xs" style="color: var(--bbg-gray-muted)">
      <span>beyondbordergroup.com</span>
      <span>Updated {new Date().toLocaleDateString('en-CA')}</span>
    </div>
  </footer>

  <script>
    if (sessionStorage.getItem('bbg_auth') !== 'true') {
      window.location.replace('/login');
    }
  </script>

  <!-- Global project context: drives every [data-project-panel] on the page -->
  <script>
    import { listProjects } from '../scripts/projects';

    const PROJECT_KEY = 'bbg_active_project';
    const select = document.getElementById('project-select') as HTMLSelectElement | null;
    const dot = document.getElementById('project-dot');
    const main = document.querySelector('main');

    // Lazily-created "no data for this project yet" panel for scoped pages.
    let fallbackEl: HTMLElement | null = null;
    function fallback(): HTMLElement {
      if (fallbackEl) return fallbackEl;
      fallbackEl = document.createElement('div');
      fallbackEl.className =
        'hidden rounded-3xl border border-dashed border-gray-200 p-12 text-center';
      fallbackEl.innerHTML =
        '<div class="text-gray-400 mb-1">No data yet for <span class="font-semibold" data-active-project-name>this project</span>.</div>' +
        '<div class="text-xs text-gray-400">Add content for this section, or manage projects on the <a href="/projects" class="underline">Projects</a> page.</div>';
      main!.appendChild(fallbackEl);
      return fallbackEl;
    }

    // The project store (localStorage) is the source of truth once a browser has
    // edited the set. Rebuild the <select> options from it so created / renamed /
    // deleted projects are reflected on every page.
    function syncOptions() {
      if (!select) return;
      const projects = listProjects();
      const desired = projects.map(p => p.id).join(',');
      const current = Array.from(select.options).map(o => o.value).join(',');
      if (desired === current) {
        // Same set/order — still refresh labels & colors in case of edits.
        projects.forEach((p, i) => {
          const opt = select.options[i];
          if (opt) { opt.text = p.name; opt.dataset.color = p.color; }
        });
        return;
      }
      select.innerHTML = '';
      for (const p of projects) {
        const opt = document.createElement('option');
        opt.value = p.id;
        opt.text = p.name;
        opt.dataset.color = p.color;
        select.appendChild(opt);
      }
    }

    function ids(): string[] {
      return select ? Array.from(select.options).map(o => o.value) : [];
    }
    function activeId(): string {
      const saved = localStorage.getItem(PROJECT_KEY);
      const list = ids();
      return saved && list.includes(saved) ? saved : (list[0] || '');
    }
    function setNames(name: string) {
      document.querySelectorAll<HTMLElement>('[data-active-project-name]').forEach(el => { el.textContent = name; });
    }
    function apply(id: string) {
      let name = '';
      if (select) {
        select.value = id;
        const opt = select.options[select.selectedIndex];
        if (dot && opt) dot.style.background = opt.dataset.color || 'var(--bbg-gray-dark)';
        name = opt ? opt.text : '';
        setNames(name);
      }
      // Show only the active project's panels (pages that aren't scoped have none).
      const panels = document.querySelectorAll<HTMLElement>('[data-project-panel]');
      let matched = false;
      panels.forEach(p => {
        const show = p.dataset.projectPanel === id;
        if (show) matched = true;
        p.classList.toggle('hidden', !show);
      });
      // Scoped page, but this project has no server-rendered panel (e.g. a
      // project created in-browser). Show a graceful empty state instead of a
      // blank screen — its data sections just don't exist yet.
      if (main) {
        if (panels.length > 0 && !matched) {
          fallback().classList.remove('hidden');
          setNames(name); // fill the name inside the freshly-shown fallback
        } else if (fallbackEl) {
          fallbackEl.classList.add('hidden');
        }
      }
      // Let scoped pages react (e.g. update headings/empty states if needed).
      document.dispatchEvent(new CustomEvent('projectchange', { detail: { id } }));
    }

    if (select) {
      select.addEventListener('change', () => {
        localStorage.setItem(PROJECT_KEY, select.value);
        apply(select.value);
      });
    }
    // Allow other UI (home cards, GTM tabs) to set the active project.
    document.addEventListener('setproject', (e: any) => {
      const id = e?.detail?.id;
      if (!id) return;
      localStorage.setItem(PROJECT_KEY, id);
      apply(id);
    });

    // The /gtm board fires this after any create / edit / delete.
    document.addEventListener('projectsupdated', () => {
      syncOptions();
      apply(activeId());
    });

    syncOptions();
    apply(activeId());
  </script>
</body>
</html>
