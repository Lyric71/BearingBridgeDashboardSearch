---
import '../styles/global.css';
import { projects } from '../lib/projects';
interface Props { title: string; scoped?: boolean; module?: string; }
const { title, scoped = false, module } = Astro.props;
// Each nav item may belong to a module; it's hidden when the active project
// has that module turned off. Items with no module are always shown.
const nav = [
  { label: 'Projects', href: '/projects' },
  { label: 'Dashboard', href: '/' },
  { label: 'GTM Kanban', href: '/gtm', module: 'kanban' },
  { label: 'Keywords', href: '/seo/keywords', module: 'seo' },
  { label: 'Competitors', href: '/seo/competitors', module: 'seo' },
  { label: 'Google Ads', href: '/sem/ads', module: 'googleAds' },
  { label: 'Click Report', href: '/sem/report', module: 'googleAds' },
];
const current = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" href="/icon.png" />
  <link rel="apple-touch-icon" href="/apple-icon.png" />
  <title>{title} — BearingBridge - Search Dashboard</title>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Header -->
  <header class="border-b border-border">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/">
        <img
          src="/logo.svg"
          alt="BearingBridge"
          class="h-8 w-auto"
        />
      </a>
      <nav class="flex items-center gap-1">
        {nav.map(item => (
          <a
            href={item.href}
            data-nav-module={item.module}
            class={`px-3 py-1.5 rounded-md text-sm font-medium transition-colors ${
              current === item.href
                ? 'bg-primary text-primary-foreground'
                : 'text-muted-foreground hover:text-foreground hover:bg-muted'
            }`}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Project context bar: the project is the top-level entry -->
    <div class="border-t border-border bg-muted/40">
      <div class="max-w-7xl mx-auto px-6 py-2.5 flex items-center gap-3">
        <span class="ui-eyebrow">Project</span>
        <div class="relative">
          <span id="project-dot" class="absolute left-3 top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full" style="background: var(--bbg-gray-dark)"></span>
          <select
            id="project-select"
            class="appearance-none text-sm font-semibold rounded-lg border border-input bg-background pl-8 pr-9 py-1.5 cursor-pointer hover:border-ring focus:outline-none focus:border-ring"
          >
            {projects.map(p => (
              <option value={p.id} data-color={p.color}>{p.name}</option>
            ))}
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </div>
        <a href="/projects" class="link-muted text-xs">Manage projects &rarr;</a>
      </div>
    </div>
  </header>

  <!-- Page -->
  <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-10" data-page-module={module}>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-border mt-auto">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center text-xs" style="color: var(--bbg-gray-muted)">
      <span>www.bearingbridge.com</span>
      <span>Updated {new Date().toLocaleDateString('en-CA')}</span>
    </div>
  </footer>

  <script>
    if (sessionStorage.getItem('bbg_auth') !== 'true') {
      window.location.replace('/login');
    }
  </script>

  <!-- Global project context: drives every [data-project-panel] on the page -->
  <script>
    import { listProjects, MODULES } from '../scripts/projects';

    const PROJECT_KEY = 'bbg_active_project';
    const select = document.getElementById('project-select') as HTMLSelectElement | null;
    const dot = document.getElementById('project-dot');
    const main = document.querySelector('main');

    const moduleLabel = (key: string) =>
      MODULES.find(m => m.key === key)?.label ?? key;
    function modulesOf(id: string): Record<string, boolean> | null {
      const p = listProjects().find(x => x.id === id);
      return p ? (p.modules as unknown as Record<string, boolean>) : null;
    }

    // Lazily-created notice panel for scoped pages (empty data / disabled module).
    let fallbackEl: HTMLElement | null = null;
    function showFallback(html: string) {
      if (!main) return;
      if (!fallbackEl) {
        fallbackEl = document.createElement('div');
        main.appendChild(fallbackEl);
      }
      fallbackEl.className = 'ui-empty';
      fallbackEl.innerHTML = html;
    }
    function hideFallback() { fallbackEl?.classList.add('hidden'); }

    // The project store (localStorage) is the source of truth once a browser has
    // edited the set. Rebuild the <select> options from it so created / renamed /
    // deleted projects are reflected on every page.
    function syncOptions() {
      if (!select) return;
      const projects = listProjects();
      const desired = projects.map(p => p.id).join(',');
      const current = Array.from(select.options).map(o => o.value).join(',');
      if (desired === current) {
        // Same set/order — still refresh labels & colors in case of edits.
        projects.forEach((p, i) => {
          const opt = select.options[i];
          if (opt) { opt.text = p.name; opt.dataset.color = p.color; }
        });
        return;
      }
      select.innerHTML = '';
      for (const p of projects) {
        const opt = document.createElement('option');
        opt.value = p.id;
        opt.text = p.name;
        opt.dataset.color = p.color;
        select.appendChild(opt);
      }
    }

    function ids(): string[] {
      return select ? Array.from(select.options).map(o => o.value) : [];
    }
    function activeId(): string {
      const saved = localStorage.getItem(PROJECT_KEY);
      const list = ids();
      return saved && list.includes(saved) ? saved : (list[0] || '');
    }
    function setNames(name: string) {
      document.querySelectorAll<HTMLElement>('[data-active-project-name]').forEach(el => { el.textContent = name; });
    }
    function apply(id: string) {
      let name = '';
      if (select) {
        select.value = id;
        const opt = select.options[select.selectedIndex];
        if (dot && opt) dot.style.background = opt.dataset.color || 'var(--bbg-gray-dark)';
        name = opt ? opt.text : '';
        setNames(name);
      }
      // Hide nav entries / dashboard sections for modules this project turned off.
      const mods = modulesOf(id);
      document.querySelectorAll<HTMLElement>('[data-nav-module]').forEach(el => {
        const m = el.dataset.navModule!;
        el.classList.toggle('hidden', !!mods && !mods[m]);
      });

      const panels = document.querySelectorAll<HTMLElement>('[data-project-panel]');
      const pageModule = main?.dataset.pageModule || '';

      if (pageModule && mods && !mods[pageModule]) {
        // The page's module is disabled for this project — gate the whole page.
        panels.forEach(p => p.classList.add('hidden'));
        showFallback(
          `<div class="text-gray-400 mb-1">The <span class="font-semibold">${moduleLabel(pageModule)}</span> module isn't enabled for <span class="font-semibold">${name || 'this project'}</span>.</div>` +
          '<div class="text-xs text-gray-400">Enable it on the <a href="/projects" class="underline">Projects</a> page.</div>',
        );
      } else {
        // Show only the active project's panels (pages that aren't scoped have none).
        let matched = false;
        panels.forEach(p => {
          const show = p.dataset.projectPanel === id;
          if (show) matched = true;
          p.classList.toggle('hidden', !show);
        });
        // Scoped page, but this project has no server-rendered panel (e.g. a
        // project created in-browser). Show a graceful empty state.
        if (main && panels.length > 0 && !matched) {
          showFallback(
            `<div class="text-gray-400 mb-1">No data yet for <span class="font-semibold">${name || 'this project'}</span>.</div>` +
            '<div class="text-xs text-gray-400">Add content for this section, or manage projects on the <a href="/projects" class="underline">Projects</a> page.</div>',
          );
        } else {
          hideFallback();
        }
      }
      // Let scoped pages react (e.g. update headings/empty states if needed).
      document.dispatchEvent(new CustomEvent('projectchange', { detail: { id } }));
    }

    if (select) {
      select.addEventListener('change', () => {
        localStorage.setItem(PROJECT_KEY, select.value);
        apply(select.value);
      });
    }
    // Allow other UI (home cards, GTM tabs) to set the active project.
    document.addEventListener('setproject', (e: any) => {
      const id = e?.detail?.id;
      if (!id) return;
      localStorage.setItem(PROJECT_KEY, id);
      apply(id);
    });

    // The /gtm board fires this after any create / edit / delete.
    document.addEventListener('projectsupdated', () => {
      syncOptions();
      apply(activeId());
    });

    syncOptions();
    apply(activeId());
  </script>
</body>
</html>
