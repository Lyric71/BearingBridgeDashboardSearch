const bbgNegativeKeywords = [
  'jobs','salary','career','internship','intern','course','training','free','PDF','download',
  'template','wikipedia','what is','definition','meaning','tutorial','example','sample',
  'case study','book','certification','degree','masters','MBA','reddit','quora','blog',
  'news','amazon','alibaba','aliexpress','wish','shein','temu','how to','diy','guide',
  'tips','checklist',
];

// Per-project ad campaigns. Only Beyond Border Group is built out today.
const adsByProject: Record<string, { campaigns: typeof bbgCampaigns; negativeKeywords: string[] }> = {
  beyondbordergroup: { campaigns: bbgCampaigns, negativeKeywords: bbgNegativeKeywords },
};

const byProject = projects.map(p => {
  const ads = adsByProject[p.id] ?? { campaigns: [], negativeKeywords: [] };
  const totalAdGroups = ads.campaigns.reduce((sum, c) => sum + c.adGroups.length, 0);
  const totalKeywords = ads.campaigns.reduce((sum, c) => sum + c.adGroups.reduce((s, ag) => s + ag.keywords.length, 0), 0);
  return { ...p, ...ads, totalAdGroups, totalKeywords };
});
---
<Layout title="Google Ads" scoped module="googleAds">
  <div class="mb-8">
    <a href="/" class="text-sm text-gray-400 hover:text-gray-600 mb-4 inline-block">&larr; Dashboard</a>
    <h1 class="text-3xl font-bold mb-2" style="color: var(--bbg-orange)">Google Ads Campaigns</h1>
    <p class="text-gray-500 mb-1">Campaign structure, ad groups, RSA copy &amp; negatives · <span data-active-project-name>this project</span></p>
  </div>

  {byProject.map(p => (
    <div data-project-panel={p.id} class="hidden">
      {p.campaigns.length === 0 ? (
        <div class="rounded-3xl border border-dashed border-gray-200 p-12 text-center">
          <div class="text-gray-400 mb-1">No Google Ads campaigns for <span class="font-semibold" style={`color: ${p.color}`}>{p.name}</span> yet.</div>
          <div class="text-xs text-gray-400">Build out the campaign plan for this project to populate this view.</div>
        </div>
      ) : (
      <>
      <p class="text-gray-400 text-sm mb-6">{p.campaigns.length} campaigns · {p.totalAdGroups} ad groups · {p.totalKeywords} keywords</p>
  {p.campaigns.map(campaign => (
    <div class="mb-10 border border-gray-200 rounded-xl overflow-hidden">
      <!-- Campaign header -->
      <div class="px-6 py-4 flex items-center gap-3" style={`background: ${campaign.color}18; border-bottom: 2px solid ${campaign.color}`}>
        <span class="text-xs font-bold px-2 py-0.5 rounded text-white" style={`background: ${campaign.color}`}>{campaign.id}</span>
        <h2 class="font-bold text-lg" style={`color: ${campaign.color}`}>{campaign.name}</h2>
        <span class="ml-auto text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded">PAUSED</span>
        <span class="text-xs text-gray-400">{campaign.adGroups.length} ad groups · {campaign.adGroups.reduce((s, ag) => s + ag.keywords.length, 0)} kw</span>
      </div>

      <!-- Ad groups -->
      <div class="divide-y divide-gray-100">
        {campaign.adGroups.map(ag => (
          <details class="group">
            <summary class="flex items-center gap-3 px-6 py-3 cursor-pointer hover:bg-gray-50 list-none">
              <span class="text-xs font-mono font-bold text-gray-400">{ag.id}</span>
              <span class="font-medium text-gray-800">{ag.name}</span>
              <span class="text-xs text-gray-400 ml-1">{ag.keywords.length} kw · {ag.headlines.length} headlines</span>
              <svg class="ml-auto w-4 h-4 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>

            <div class="px-6 pb-5 pt-1 grid grid-cols-1 md:grid-cols-3 gap-5">
              <!-- Keywords -->
              <div>
                <div class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-2">Keywords</div>
                <ul class="space-y-1">
                  {ag.keywords.map(kw => (
                    <li class="text-sm text-gray-700 bg-gray-50 rounded px-2 py-0.5 font-mono">{kw}</li>
                  ))}
                </ul>
              </div>

              <!-- Headlines -->
              <div>
                <div class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-2">Headlines <span class="normal-case font-normal">(≤30 chars)</span></div>
                <ol class="space-y-1">
                  {ag.headlines.map((h, i) => (
                    <li class="text-sm text-gray-700 flex gap-2">
                      <span class="text-gray-300 font-mono text-xs w-4 shrink-0 pt-0.5">{i+1}</span>
                      <span>{h}</span>
                      <span class="ml-auto text-gray-300 font-mono text-xs shrink-0">{h.length}</span>
                    </li>
                  ))}
                </ol>
              </div>

              <!-- Descriptions -->
              <div>
                <div class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-2">Descriptions <span class="normal-case font-normal">(≤90 chars)</span></div>
                <ol class="space-y-2">
                  {ag.descriptions.map((d, i) => (
                    <li class="text-sm text-gray-700 flex gap-2">
                      <span class="text-gray-300 font-mono text-xs w-4 shrink-0 pt-0.5">{i+1}</span>
                      <span class="leading-snug">{d}</span>
                      <span class="ml-auto text-gray-300 font-mono text-xs shrink-0">{d.length}</span>
                    </li>
                  ))}
                </ol>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  ))}

  <!-- Negative keywords -->
  <div class="border border-gray-200 rounded-xl overflow-hidden">
    <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
      <h2 class="font-bold text-gray-700">Global Negative Keywords</h2>
      <p class="text-xs text-gray-400 mt-0.5">Shared across all campaigns · {p.negativeKeywords.length} terms</p>
    </div>
    <div class="px-6 py-4 flex flex-wrap gap-2">
      {p.negativeKeywords.map(kw => (
        <span class="text-xs bg-red-50 text-red-600 border border-red-100 rounded px-2 py-0.5 font-mono">{kw}</span>
      ))}
    </div>
  </div>
      </>
      )}
    </div>
  ))}
</Layout>
