---
import { createHash } from 'node:crypto';
import '../styles/global.css';

// Credentials come from env vars (.env locally, project settings on Vercel).
// We only ship the SHA-256 hash to the client, never the raw values.
const login = import.meta.env.SITE_LOGIN;
const password = import.meta.env.SITE_PASSWORD;

if (!login || !password) {
  throw new Error('Missing SITE_LOGIN / SITE_PASSWORD env vars for the login page.');
}

const validHash = createHash('sha256').update(`${login}:${password}`).digest('hex');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" href="/icon.png" />
  <link rel="apple-touch-icon" href="/apple-icon.png" />
  <title>Login — BearingBridge - Search Dashboard</title>
</head>
<body class="min-h-screen flex items-center justify-center bg-muted" data-valid-hash={validHash}>
  <div class="w-full max-w-sm">
    <div class="ui-card p-8 shadow-xl">
      <div class="flex justify-center mb-6">
        <img
          src="/logo.svg"
          alt="BearingBridge"
          class="h-8 w-auto"
        />
      </div>
      <h1 class="text-xl font-bold text-center mb-1">SEO & Ads Intelligence</h1>
      <p class="text-sm text-muted-foreground text-center mb-6">Sign in to access reports</p>

      <form id="login-form" class="space-y-4">
        <div>
          <label for="username" class="block text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-1">Login</label>
          <input
            id="username"
            type="text"
            autocomplete="username"
            required
            class="ui-input px-4 py-2.5"
            placeholder="Enter login"
          />
        </div>
        <div>
          <label for="password" class="block text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-1">Password</label>
          <input
            id="password"
            type="password"
            autocomplete="current-password"
            required
            class="ui-input px-4 py-2.5"
            placeholder="Enter password"
          />
        </div>
        <p id="error-msg" class="text-sm text-red-500 hidden">Invalid login or password.</p>
        <button
          type="submit"
          class="btn-primary w-full py-2.5"
        >
          Sign in
        </button>
      </form>
    </div>
    <p class="text-center text-xs mt-4" style="color: var(--bbg-gray-muted)">www.bearingbridge.com</p>
  </div>

  <script>
    // Hash credentials so they're not in plain text in the built JS
    async function sha256(str: string): Promise<string> {
      const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
      return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
    }

    // SHA-256 of "login:password" computed at build time from env vars
    const VALID_HASH = document.body.dataset.validHash!;

    // If already logged in, go to dashboard
    if (sessionStorage.getItem('bbg_auth') === 'true') {
      window.location.replace('/');
    }

    document.getElementById('login-form')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const user = (document.getElementById('username') as HTMLInputElement).value;
      const pass = (document.getElementById('password') as HTMLInputElement).value;
      const hash = await sha256(user + ':' + pass);

      if (hash === VALID_HASH) {
        sessionStorage.setItem('bbg_auth', 'true');
        window.location.replace('/');
      } else {
        document.getElementById('error-msg')!.classList.remove('hidden');
      }
    });
  </script>
</body>
</html>
