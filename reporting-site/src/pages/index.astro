---
import Layout from '../layouts/Layout.astro';
import gtm from '../data/gtm.json';
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from '../components/ui/card';
import { Badge } from '../components/ui/badge';

// Curated SEO/Ads headline metrics — only Beyond Border Group has analytics today.
const curatedStats: Record<string, { metric: string; value: string; note: string; color: string }[]> = {
  beyondbordergroup: [
    { metric: 'Keywords tracked',    value: '160',         note: 'EN across 8 categories',                      color: 'var(--bbg-blue)' },
    { metric: 'Competitors tracked', value: '27',          note: 'China ecommerce & market entry agencies',     color: 'var(--bbg-red)' },
    { metric: 'Best rank (EN)',      value: '#2',          note: '"china cross border ecommerce consulting"',   color: 'var(--bbg-orange)' },
    { metric: 'Page 1 keywords',     value: '0',           note: 'Core consulting terms — all page 2+',         color: 'var(--bbg-gray-muted)' },
    { metric: 'Biggest opportunity', value: 'Market Entry',note: 'Low competition vs search volume',            color: 'var(--bbg-purple)' },
  ],
};

// Per-project status: curated analytics if present, otherwise the project's own
// GTM build-out signals (never another project's numbers).
const statusByProject = gtm.projects.map(p => {
  const done = p.tasks.filter(t => t.status === 'done').length;
  return {
    id: p.id,
    name: p.name,
    color: p.color,
    owner: p.owner,
    channels: p.channels,
    tasksDone: done,
    tasksTotal: p.tasks.length,
    curated: curatedStats[p.id] ?? null,
  };
});

const seo = [
  { slug: '/seo/keywords',    label: 'Keywords',    color: 'var(--bbg-blue)',   icon: '🔍', description: 'Keyword audits, volume, difficulty and opportunity mapping.' },
  { slug: '/seo/competitors', label: 'Competitors', color: 'var(--bbg-red)',    icon: '⚔️', description: 'SERP rank tracking vs top 10 competitors per keyword group.' },
  { slug: '/seo/content-plan', label: 'Content Plan', color: 'var(--bbg-purple)', icon: '📝', description: 'Editorial pipeline of planned pages and posts per keyword cluster.', comingSoon: true },
];

const sem = [
  { slug: '/sem/ads', label: 'Google Ads', color: 'var(--bbg-orange)', icon: '📢', description: 'RSA ad copy, campaign structure and keyword recommendations.' },
  { slug: '/sem/report', label: 'Click Report', color: 'var(--bbg-red)', icon: '📊', description: 'Keyword clicks, impressions and cost per click by campaign.' },
];

// Soft brand-tinted chip background for module icons (plain HTML span — string style).
const tint = (color: string) => `background-color: color-mix(in srgb, ${color} 14%, transparent)`;
const sectionLabel = 'text-xs font-semibold uppercase tracking-widest text-muted-foreground';
---
<Layout title="Dashboard">
  <!-- Page heading -->
  <div class="mb-10">
    <h1 class="font-heading text-3xl font-bold tracking-tight mb-1">
      <span data-active-project-name>Project</span>
      <span class="text-muted-foreground font-normal">· SEO &amp; Ads Intelligence</span>
    </h1>
    <p class="text-muted-foreground">Select a project above — every view below is scoped to it.</p>
  </div>

  <!-- Snapshot: KPI stat cards, scoped to the selected project -->
  <section class="mb-12">
    <h2 class={`${sectionLabel} mb-4`}>Snapshot · <span data-active-project-name>project</span></h2>
    {statusByProject.map(p => (
      <div data-project-panel={p.id} class="hidden">
        {p.curated ? (
          <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-5">
            {p.curated.map(s => (
              <Card size="sm" className="justify-between">
                <CardHeader>
                  <CardDescription className="text-[11px] font-medium uppercase tracking-wider">{s.metric}</CardDescription>
                  <CardTitle className="text-2xl font-bold tabular-nums" style={{ color: s.color }}>{s.value}</CardTitle>
                </CardHeader>
                <CardContent className="text-xs text-muted-foreground leading-snug">{s.note}</CardContent>
              </Card>
            ))}
          </div>
        ) : (
          <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
            <Card size="sm" className="justify-between">
              <CardHeader>
                <CardDescription className="text-[11px] font-medium uppercase tracking-wider">GTM tasks done</CardDescription>
                <CardTitle className="text-2xl font-bold tabular-nums" style={{ color: p.color }}>{p.tasksDone} / {p.tasksTotal}</CardTitle>
              </CardHeader>
              <CardContent className="text-xs text-muted-foreground leading-snug">Go-to-market build-out progress</CardContent>
            </Card>
            <Card size="sm" className="justify-between">
              <CardHeader>
                <CardDescription className="text-[11px] font-medium uppercase tracking-wider">Owner</CardDescription>
                <CardTitle className="text-2xl font-bold">{p.owner}</CardTitle>
              </CardHeader>
              <CardContent className="text-xs text-muted-foreground leading-snug">Responsible for execution</CardContent>
            </Card>
            <Card size="sm" className="justify-between">
              <CardHeader>
                <CardDescription className="text-[11px] font-medium uppercase tracking-wider">Channels</CardDescription>
                <CardTitle className="text-base font-semibold leading-snug" style={{ color: p.color }}>
                  SEO · {p.channels.seo}<br />SEM · {p.channels.sem}
                </CardTitle>
              </CardHeader>
              <CardContent className="text-xs text-muted-foreground leading-snug">Search &amp; paid search</CardContent>
            </Card>
            <Card size="sm" className="justify-between">
              <CardHeader>
                <CardDescription className="text-[11px] font-medium uppercase tracking-wider">Analytics</CardDescription>
                <div class="pt-1"><Badge variant="outline">Not connected</Badge></div>
              </CardHeader>
              <CardContent className="text-xs text-muted-foreground leading-snug">No keyword / rank / click data yet for this project</CardContent>
            </Card>
          </div>
        )}
      </div>
    ))}
  </section>

  <!-- SEO -->
  <section class="mb-12" data-nav-module="seo">
    <h2 class={`${sectionLabel} mb-4`}>SEO</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {seo.map(t => (
        t.comingSoon ? (
          <Card className="h-full border border-dashed border-border opacity-70 ring-0">
            <CardHeader>
              <div class="flex items-center justify-between">
                <span class="flex h-11 w-11 items-center justify-center rounded-xl text-xl grayscale" style={tint(t.color)}>{t.icon}</span>
                <Badge variant="outline">Coming soon</Badge>
              </div>
              <CardTitle className="font-bold text-base mt-2">{t.label}</CardTitle>
              <CardDescription className="leading-relaxed">{t.description}</CardDescription>
            </CardHeader>
          </Card>
        ) : (
          <a href={t.slug} class="group block">
            <Card className="h-full transition-all duration-200 group-hover:-translate-y-1 group-hover:ring-foreground/20 group-hover:shadow-lg">
              <CardHeader>
                <div class="flex items-center justify-between">
                  <span class="flex h-11 w-11 items-center justify-center rounded-xl text-xl" style={tint(t.color)}>{t.icon}</span>
                  <span class="text-muted-foreground transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
                </div>
                <CardTitle className="font-bold text-base mt-2" style={{ color: t.color }}>{t.label}</CardTitle>
                <CardDescription className="leading-relaxed">{t.description}</CardDescription>
              </CardHeader>
            </Card>
          </a>
        )
      ))}
    </div>
  </section>

  <!-- SEM / Google Ads -->
  <section class="mb-12" data-nav-module="googleAds">
    <h2 class={`${sectionLabel} mb-4`}>SEM / Google Ads</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {sem.map(t => (
        <a href={t.slug} class="group block">
          <Card className="h-full transition-all duration-200 group-hover:-translate-y-1 group-hover:ring-foreground/20 group-hover:shadow-lg">
            <CardHeader>
              <div class="flex items-center justify-between">
                <span class="flex h-11 w-11 items-center justify-center rounded-xl text-xl" style={tint(t.color)}>{t.icon}</span>
                <span class="text-muted-foreground transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
              </div>
              <CardTitle className="font-bold text-base mt-2" style={{ color: t.color }}>{t.label}</CardTitle>
              <CardDescription className="leading-relaxed">{t.description}</CardDescription>
            </CardHeader>
          </Card>
        </a>
      ))}
    </div>
  </section>

  <!-- GTM Kanban — selected project only -->
  <section data-nav-module="kanban">
    <div class="flex items-center justify-between mb-4">
      <h2 class={sectionLabel}>GTM Board · <span data-active-project-name>project</span></h2>
      <a href="/gtm" class="text-xs font-medium hover:underline" style="color: var(--bbg-blue)">Full board &rarr;</a>
    </div>
    <Card className="ring-0 border border-border">
      <CardContent className="px-3 py-1">
        <div id="project-board-compact"></div>
      </CardContent>
    </Card>
  </section>
</Layout>

<script>
  import { mountProjectBoard } from '../scripts/projectBoard';
  mountProjectBoard('compact', 'project-board-compact');
</script>
