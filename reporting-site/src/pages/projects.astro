---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Projects">
  <div class="mb-8">
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <h1 class="font-heading text-3xl font-bold tracking-tight mb-2">Projects</h1>
        <p class="text-muted-foreground text-sm"><span data-project-total>0</span> projects · the top-level entity — every SEO, SEM &amp; GTM view is scoped to the project you select · each project must be linked to a website · changes are saved to the shared database</p>
      </div>
      <div class="flex items-center gap-2">
        <button data-project-new class="btn-primary">
          + New project
        </button>
      </div>
    </div>
  </div>

  <!-- Project cards are rendered client-side from the project store. -->
  <div id="projects-grid" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3"></div>
</Layout>

<script>
  import { mountProjectsAdmin } from '../scripts/projectsAdmin';
  mountProjectsAdmin();
</script>
