---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Projects">
  <div class="mb-8">
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <h1 class="text-3xl font-bold mb-2" style="color: var(--bbg-gray-dark)">Projects</h1>
        <p class="text-gray-400 text-sm"><span data-project-total>0</span> projects · the top-level entity — every SEO, SEM &amp; GTM view is scoped to the project you select · changes save in this browser</p>
      </div>
      <div class="flex items-center gap-2">
        <button data-project-new class="text-sm px-4 py-2 rounded-lg text-white font-semibold transition-colors" style="background: var(--bbg-gray-dark)">
          + New project
        </button>
        <button data-projects-reset class="text-xs px-3 py-2 rounded-lg border border-gray-200 text-gray-500 hover:border-gray-400 hover:text-gray-700 transition-colors">
          Reset to plan
        </button>
      </div>
    </div>
  </div>

  <!-- Project cards are rendered client-side from the project store. -->
  <div id="projects-grid" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3"></div>
</Layout>

<script>
  import { mountProjectsAdmin } from '../scripts/projectsAdmin';
  mountProjectsAdmin();
</script>
