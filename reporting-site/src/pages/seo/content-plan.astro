---
import Layout from '../../layouts/Layout.astro';
import SeoNav from '../../components/SeoNav.astro';
import { marked } from 'marked';
import { listProjects } from '../../lib/projects-db';
import { listKeywordsGrouped } from '../../lib/keywords-db';
import { listContentPlans } from '../../lib/content-plan-db';
import { listBlogArticles, type BlogArticle } from '../../lib/blog-articles-db';

const [projects, keywordsByProject, plans, articles] = await Promise.all([
  listProjects(), listKeywordsGrouped(), listContentPlans(), listBlogArticles(),
]);

// Group saved plans by project id (null-project plans land under '').
const plansByProject: Record<string, typeof plans> = {};
for (const p of plans) (plansByProject[p.project_id ?? ''] ??= []).push(p);

// Group blog articles by their content plan id.
const articlesByPlan: Record<string, BlogArticle[]> = {};
for (const a of articles) if (a.content_plan_id) (articlesByPlan[a.content_plan_id] ??= []).push(a);

// Known blog base URLs so the blog form pre-fills where the articles live.
const BLOG_BASE: Record<string, string> = {
  chinawebfoundry: 'https://www.chinawebfoundry.com/resources/china-web-guide/',
};

const fmtDate = (iso: string) => new Date(iso).toLocaleDateString('en-CA');
const clustersOf = (kws: { cluster: string }[]) =>
  [...new Set(kws.map(k => k.cluster).filter(Boolean))].sort();
---
<Layout title="Content Plan" scoped module="seo">
  <div class="mb-8">
    <a href="/" class="link-muted mb-4 inline-block">&larr; Dashboard</a>
    <h1 class="font-heading text-3xl font-bold tracking-tight mb-2" style="color: var(--bbg-purple)">🧭 Content Plan</h1>
    <p class="text-muted-foreground">Draft a landing page (single keyword) or a blog plan (whole cluster) · <span data-active-project-name>this project</span> · <span class="text-muted-foreground/70">live SERP + Claude, saved to the shared database</span></p>
    <SeoNav current="content-plan" />
  </div>

  {projects.map(p => {
    const kws = keywordsByProject[p.id] ?? [];
    const clusters = clustersOf(kws);
    const saved = plansByProject[p.id] ?? [];
    const landing = saved.filter(s => s.kind !== 'blog');
    const blog = saved.filter(s => s.kind === 'blog');
    return (
      <div data-project-panel={p.id} class="hidden">
        <div data-cp-panel data-project={p.id} data-project-name={p.name}>
          <!-- Keyword datalist + intent lookup for this project -->
          <script type="application/json" data-cp-keywords is:inline set:html={JSON.stringify(
            kws.map(k => ({ keyword: k.keyword, intent: k.intent, language: k.language }))
          )}></script>
          <!-- Blog articles for this project's plans (client renders the cards) -->
          <script type="application/json" data-cp-articles-data is:inline set:html={JSON.stringify(
            Object.fromEntries(blog.map(pl => [pl.id, articlesByPlan[pl.id] ?? []]))
          )}></script>

          <!-- Mode toggle -->
          <div class="inline-flex rounded-lg border border-border p-1 mb-4 bg-muted/40">
            <button type="button" data-cp-mode="landing" class="px-4 py-1.5 rounded-md text-sm font-medium transition-colors">🛬 Landing page</button>
            <button type="button" data-cp-mode="blog" class="px-4 py-1.5 rounded-md text-sm font-medium transition-colors">📝 Blog articles</button>
          </div>

          <!-- Landing form (single keyword) -->
          <div class="ui-card p-5 mb-6" data-cp-form-wrap="landing">
            <form data-cp-form data-kind="landing" class="grid gap-4 sm:grid-cols-2">
              <div class="sm:col-span-2">
                <label class="ui-eyebrow block mb-1">Keyword</label>
                <input
                  name="keyword"
                  list={`cp-kw-${p.id}`}
                  autocomplete="off"
                  placeholder="Pick a tracked keyword or type one…"
                  class="ui-input w-full"
                />
                <datalist id={`cp-kw-${p.id}`}>
                  {kws.map(k => <option value={k.keyword}>{k.intent ?? ''}</option>)}
                </datalist>
              </div>
              <div>
                <label class="ui-eyebrow block mb-1">Language</label>
                <select name="language" class="ui-select w-full">
                  <option value="EN">EN</option>
                  <option value="FR">FR</option>
                </select>
              </div>
              <div>
                <label class="ui-eyebrow block mb-1">Target URL <span class="text-muted-foreground/70 normal-case font-normal">(optional)</span></label>
                <input name="targetUrl" type="url" placeholder="https://…" class="ui-input w-full" />
              </div>
              <input type="hidden" name="intent" />
              <div class="sm:col-span-2 flex items-center gap-3">
                <button type="submit" class="btn-primary">🛬 Landing page</button>
                <span data-cp-phase class="text-xs text-muted-foreground"></span>
              </div>
            </form>
          </div>

          <!-- Blog form (whole cluster) -->
          <div class="ui-card p-5 mb-6 hidden" data-cp-form-wrap="blog">
            <form data-cp-form data-kind="blog" class="grid gap-4 sm:grid-cols-2">
              <div class="sm:col-span-2">
                <label class="ui-eyebrow block mb-1">Keyword cluster</label>
                {clusters.length === 0 ? (
                  <div class="text-xs text-muted-foreground">
                    No clusters yet for this project. Add clusters on the <a href="/seo/keywords" class="underline">Keywords</a> page.
                  </div>
                ) : (
                  <select name="cluster" class="ui-select w-full">
                    {clusters.map(c => <option value={c}>{c}</option>)}
                  </select>
                )}
              </div>
              <div>
                <label class="ui-eyebrow block mb-1">Language</label>
                <select name="language" class="ui-select w-full">
                  <option value="EN">EN</option>
                  <option value="FR">FR</option>
                </select>
              </div>
              <div>
                <label class="ui-eyebrow block mb-1">Number of new articles</label>
                <input name="articleCount" type="number" min="1" max="20" step="1" value="1" class="ui-input w-full" />
                <p class="text-[11px] text-muted-foreground mt-1">New articles are added to the cluster (existing ones are kept).</p>
              </div>
              <div class="sm:col-span-2">
                <label class="ui-eyebrow block mb-1">Blog base URL <span class="text-muted-foreground/70 normal-case font-normal">(optional)</span></label>
                <input name="targetUrl" type="url" value={BLOG_BASE[p.id] ?? ''} placeholder="https://…/blog/" class="ui-input w-full" />
              </div>
              <div class="sm:col-span-2 flex items-center gap-3">
                <button type="submit" class="btn-primary" disabled={clusters.length === 0}>📝 Blog articles</button>
                <span data-cp-phase class="text-xs text-muted-foreground"></span>
              </div>
            </form>
          </div>

          <!-- Live generation output (hidden until a run starts) -->
          <div data-cp-output class="hidden ui-card overflow-hidden mb-8">
            <div class="px-6 py-4 border-b border-border flex items-center justify-between bg-muted">
              <h2 data-cp-output-title class="font-semibold">Generating…</h2>
              <span data-cp-signals class="text-xs text-muted-foreground tabular-nums"></span>
            </div>
            <div data-cp-output-body class="p-6 prose max-w-none overflow-x-auto"></div>
          </div>

          <!-- Saved: landing -->
          <h2 class="ui-eyebrow mb-3">🛬 Landing page briefs <span class="text-muted-foreground font-normal normal-case">· newest first</span></h2>
          <div data-cp-saved="landing" class="mb-8">
            {landing.length === 0 ? (
              <div class="ui-empty"><div class="text-xs">No landing-page briefs yet. Pick a keyword above.</div></div>
            ) : landing.map(pl => (
              <details class="mb-4 ui-card overflow-hidden" data-cp-saved-item={`landing||${pl.keyword}||${pl.language}`}>
                <summary class="px-6 py-4 border-b border-border flex items-center justify-between bg-muted cursor-pointer">
                  <span class="font-semibold capitalize">{pl.keyword}</span>
                  <span class="text-xs text-muted-foreground">
                    {pl.language}
                    {pl.indicators?.volume != null ? ` · ${pl.indicators.volume.toLocaleString('en-US')}/mo` : ''}
                    {` · ${fmtDate(pl.updated_at)}`}
                  </span>
                </summary>
                <div class="p-6 prose max-w-none overflow-x-auto" set:html={marked(pl.plan_md)} />
              </details>
            ))}
          </div>

          <!-- Saved: blog. Article cards are rendered client-side from the
               data-cp-articles-data JSON above (accept / delete / publish). -->
          <h2 class="ui-eyebrow mb-3">📝 Blog article plans <span class="text-muted-foreground font-normal normal-case">· by cluster</span></h2>
          <div data-cp-saved="blog">
            <div data-cp-blog-empty class={blog.length === 0 ? 'ui-empty' : 'ui-empty hidden'}>
              <div class="text-xs">No blog plans yet. Switch to <span class="font-semibold">Blog articles</span> and pick a cluster.</div>
            </div>
            {blog.map(pl => (
              <div class="mb-6 ui-card overflow-hidden" data-cp-saved-item={`blog||${pl.keyword}||${pl.language}`} data-plan-id={pl.id} data-cluster={pl.cluster ?? pl.keyword} data-language={pl.language}>
                <div class="px-6 py-4 border-b border-border flex items-center justify-between bg-muted">
                  <span class="font-semibold">{pl.cluster ?? pl.keyword}</span>
                  <span class="text-xs text-muted-foreground">
                    {pl.language}
                    <span data-cp-article-count>{(articlesByPlan[pl.id]?.length ?? 0)}</span> article{(articlesByPlan[pl.id]?.length ?? 0) === 1 ? '' : 's'}
                    {pl.indicators?.keywordCount != null ? ` · ${pl.indicators.keywordCount} keywords` : ''}
                    {` · ${fmtDate(pl.updated_at)}`}
                  </span>
                </div>
                <div class="p-6">
                  <div data-cp-articles class="grid gap-3"></div>
                  <details class="mt-4">
                    <summary class="ui-eyebrow cursor-pointer">Plan overview & linking</summary>
                    <div data-cp-overview class="prose max-w-none overflow-x-auto mt-3" set:html={marked(pl.plan_md)} />
                  </details>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    );
  })}
</Layout>

<script>
  import { mountContentPlan } from '../../scripts/contentPlan';
  mountContentPlan();
</script>
