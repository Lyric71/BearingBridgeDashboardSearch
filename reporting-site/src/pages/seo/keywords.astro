---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../lib/projects';

// Sortable column headers. Keyword/cluster sort alphabetically; language/intent
// group rows; priority sorts by its ordinal rank (see scripts/keywords.ts).
const COLUMNS = [
  { key: 'keyword', label: 'Keyword' },
  { key: 'language', label: 'Language' },
  { key: 'intent', label: 'Intent' },
  { key: 'cluster', label: 'Cluster' },
  { key: 'priority', label: 'Priority' },
];
---
<Layout title="Keywords" scoped module="seo">
  <div class="mb-8">
    <a href="/" class="text-sm text-gray-400 hover:text-gray-600 mb-4 inline-block">&larr; Dashboard</a>
    <h1 class="text-3xl font-bold mb-2" style="color: var(--bbg-blue)">🔍 Keywords</h1>
    <p class="text-gray-500">Sortable, editable keyword list · <span data-active-project-name>this project</span> · <span class="text-gray-400">changes save in this browser</span></p>
  </div>

  {projects.map(p => (
    <div data-project-panel={p.id} class="hidden">
      <div data-kw-panel data-project={p.id}>
        <!-- Toolbar -->
        <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
          <div class="flex flex-wrap items-center gap-2">
            <div class="relative">
              <input
                data-kw-search
                type="search"
                placeholder="Search keyword or cluster…"
                class="w-56 max-w-full pl-9 pr-3 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:border-gray-500"
              />
              <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z"/></svg>
            </div>
            <select data-kw-filter="language" class="text-sm rounded-lg border border-gray-200 bg-white px-3 py-2 cursor-pointer hover:border-gray-400 focus:outline-none focus:border-gray-500">
              <option value="">All languages</option>
            </select>
            <select data-kw-filter="intent" class="text-sm rounded-lg border border-gray-200 bg-white px-3 py-2 cursor-pointer hover:border-gray-400 focus:outline-none focus:border-gray-500">
              <option value="">All intents</option>
            </select>
            <select data-kw-filter="priority" class="text-sm rounded-lg border border-gray-200 bg-white px-3 py-2 cursor-pointer hover:border-gray-400 focus:outline-none focus:border-gray-500">
              <option value="">All priorities</option>
            </select>
            <button data-kw-clear class="hidden text-xs px-2.5 py-2 rounded-lg text-gray-500 hover:text-gray-800 underline-offset-2 hover:underline">Clear</button>
          </div>
          <div class="flex items-center gap-2">
            <span data-kw-count class="text-xs text-gray-400 tabular-nums mr-1"></span>
            <button data-kw-add class="text-sm px-4 py-2 rounded-lg text-white font-semibold transition-colors" style="background: var(--bbg-gray-dark)">+ Add keyword</button>
            <button data-kw-reset class="text-xs px-3 py-2 rounded-lg border border-gray-200 text-gray-500 hover:border-gray-400 hover:text-gray-700 transition-colors">Reset</button>
          </div>
        </div>

        <!-- Table -->
        <div data-kw-table class="hidden overflow-x-auto rounded-2xl border border-gray-100" style="box-shadow: 10px 5px 10px rgba(0,0,0,0.05)">
          <table>
            <thead>
              <tr>
                {COLUMNS.map(c => (
                  <th data-sort={c.key} class="cursor-pointer select-none whitespace-nowrap hover:opacity-90">
                    <span class="inline-flex items-center gap-1">{c.label}<span data-caret class="text-[10px] w-2 inline-block"></span></span>
                  </th>
                ))}
                <th class="text-right">Actions</th>
              </tr>
            </thead>
            <tbody data-kw-body></tbody>
          </table>
        </div>

        <!-- Empty state -->
        <div data-kw-empty class="hidden rounded-3xl border border-dashed border-gray-200 p-12 text-center">
          <div class="text-gray-400 mb-1">No keywords for <span class="font-semibold" style={`color: ${p.color}`}>{p.name}</span> yet.</div>
          <div class="text-xs text-gray-400">Click <span class="font-semibold">+ Add keyword</span> to start the list.</div>
        </div>
      </div>
    </div>
  ))}
</Layout>

<script>
  import { mountKeywordTables } from '../../scripts/keywordsTable';
  mountKeywordTables();
</script>
