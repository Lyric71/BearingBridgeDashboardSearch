---
import Layout from '../../layouts/Layout.astro';
import SeoNav from '../../components/SeoNav.astro';
import { listProjects } from '../../lib/projects-db';
import { listKeywordsGrouped } from '../../lib/keywords-db';

const [projects, keywordsByProject] = await Promise.all([listProjects(), listKeywordsGrouped()]);

// Rows are grouped by cluster (see scripts/keywordsTable.ts); these headers sort
// within each cluster group. Priority sorts by ordinal rank; the rest A→Z.
const COLUMNS = [
  { key: 'keyword', label: 'Keyword' },
  { key: 'language', label: 'Language' },
  { key: 'intent', label: 'Intent' },
  { key: 'priority', label: 'Priority' },
];
---
<Layout title="Keywords" scoped module="seo">
  <div class="mb-8">
    <a href="/" class="link-muted mb-4 inline-block">&larr; Dashboard</a>
    <h1 class="font-heading text-3xl font-bold tracking-tight mb-2" style="color: var(--bbg-blue)">🔍 Keywords</h1>
    <p class="text-muted-foreground">Sortable, editable keyword list · <span data-active-project-name>this project</span> · <span class="text-muted-foreground/70">changes are saved to the shared database</span></p>
    <SeoNav current="keywords" />
  </div>

  <!-- Server-rendered keywords for the client store to hydrate from. -->
  <script id="keywords-data" type="application/json" is:inline set:html={JSON.stringify(keywordsByProject)}></script>

  {projects.map(p => (
    <div data-project-panel={p.id} class="hidden">
      <div data-kw-panel data-project={p.id}>
        <!-- Toolbar -->
        <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
          <div class="flex flex-wrap items-center gap-2">
            <div class="relative">
              <input
                data-kw-search
                type="search"
                placeholder="Search keyword or cluster…"
                class="ui-input w-56 max-w-full pl-9 pr-3"
              />
              <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z"/></svg>
            </div>
            <select data-kw-filter="language" class="ui-select">
              <option value="">All languages</option>
            </select>
            <select data-kw-filter="intent" class="ui-select">
              <option value="">All intents</option>
            </select>
            <select data-kw-filter="priority" class="ui-select">
              <option value="">All priorities</option>
            </select>
            <button data-kw-clear class="hidden text-xs px-2.5 py-2 rounded-lg text-muted-foreground hover:text-foreground underline-offset-2 hover:underline">Clear</button>
          </div>
          <div class="flex items-center gap-2">
            <span data-kw-count class="text-xs text-muted-foreground tabular-nums mr-1"></span>
            <button data-kw-add class="btn-primary">+ Add keyword</button>
          </div>
        </div>

        <!-- Table -->
        <div data-kw-table class="hidden overflow-x-auto ui-card">
          <table>
            <thead>
              <tr>
                {COLUMNS.map(c => (
                  <th data-sort={c.key} class="cursor-pointer select-none whitespace-nowrap hover:opacity-90">
                    <span class="inline-flex items-center gap-1">{c.label}<span data-caret class="text-[10px] w-2 inline-block"></span></span>
                  </th>
                ))}
                <th class="text-right">Actions</th>
              </tr>
            </thead>
            <tbody data-kw-body></tbody>
          </table>
        </div>

        <!-- Empty state -->
        <div data-kw-empty class="hidden ui-empty">
          <div class="mb-1">No keywords for <span class="font-semibold" style={`color: ${p.color}`}>{p.name}</span> yet.</div>
          <div class="text-xs">Click <span class="font-semibold">+ Add keyword</span> to start the list.</div>
        </div>
      </div>
    </div>
  ))}
</Layout>

<script>
  import { mountKeywordTables } from '../../scripts/keywordsTable';
  mountKeywordTables();
</script>
