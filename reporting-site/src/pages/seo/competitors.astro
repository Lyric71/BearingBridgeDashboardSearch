---
import Layout from '../../layouts/Layout.astro';
import SeoNav from '../../components/SeoNav.astro';
import { marked } from 'marked';
import { listProjects } from '../../lib/projects-db';
import { listReports, listKeywordHistory, type SerpReport, type KeywordHistoryEntry } from '../../lib/serp-db';

const projects = await listProjects();

// Per project: rows in the serp_reports table (one SERP report per keyword group).
// Headline KPIs come from the overview report's indicators column; the parser
// below is only a fallback for reports whose body still carries "## Headline"
// bullet lines like:
//   - **Keywords ranked in top 100:** 17/71
// Pull them out so we can surface them as cards at the top of the page.
function parseHeadline(raw: string) {
  const start = raw.indexOf('## Headline');
  if (start < 0) return [];
  const section = raw.slice(start).split(/\n##\s/)[0];
  const out: { label: string; value: string }[] = [];
  for (const line of section.split('\n')) {
    const m = line.match(/^-\s*\*\*(.+?):\*\*\s*(.+)$/);
    if (m) out.push({ label: m[1].trim(), value: m[2].replace(/\*\*/g, '').trim() });
  }
  return out;
}

function buildGroups(reports: SerpReport[], history: KeywordHistoryEntry[]) {
  // Headline KPIs come from the overview report's parsed indicators (robust,
  // no markdown re-parsing). Falls back to parsing the body if absent.
  const overview = reports.find(r => /overview/i.test(r.cluster));
  const ind = overview?.indicators ?? null;
  const headline = ind
    ? [
        { label: 'Keywords ranked in top 100', value: `${ind.ranked ?? 0}/${ind.total ?? 0}` },
        { label: 'Keywords with dedicated on-site content', value: `${ind.covered ?? 0}/${ind.total ?? 0}` },
        { label: 'Overall ChinaWebFoundry visibility index', value: `${ind.index ?? 0}/100` },
      ]
    : overview ? parseHeadline(overview.content_md) : [];

  // Per-keyword refresh history grouped by cluster id.
  const historyByCluster = new Map<string, KeywordHistoryEntry[]>();
  for (const h of history) {
    const list = historyByCluster.get(h.cluster) ?? [];
    list.push(h);
    historyByCluster.set(h.cluster, list);
  }

  // The overview report is surfaced as the headline card above, so drop it from
  // the collapsible group list to avoid a redundant "00 Overview" section.
  const groups = reports.filter(r => !/overview/i.test(r.cluster)).map(r => {
  const cid = r.cluster;
  const raw = (r.content_md ?? '').replace(/\r\n?/g, '\n'); // normalize CRLF
  const lines = raw.split('\n');

  // Extract title from first heading (prefer the stored title).
  const titleLine = lines.find(l => l.startsWith('# '));
  const title = r.title || (titleLine ? titleLine.replace(/^#\s*SERP Report\s*[—-]\s*/, '').replace(/^#\s*/, '') : cid);

  // Extract meta line
  const metaLine = lines.find(l => l.startsWith('Date:'));
  const meta = metaLine || (r.report_date ? `Date: ${r.report_date}` : '');

  // Split into rank table section and competitors section
  const scoreSep = raw.indexOf('## Top 10 Competitors');
  const rankSection = scoreSep > -1 ? raw.slice(0, scoreSep) : raw;
  const scoreSection = scoreSep > -1 ? raw.slice(scoreSep) : '';

  // Parse BBG summary from rank table
  // Columns: | Keyword | Volume | CPC | Comp. | #1 Domain | beyondbordergroup.com | ...
  // After split on '|': [0]='', [1]=Keyword, [2]=Volume, [3]=CPC, [4]=Comp, [5]=#1Domain, [6]=BBG
  // Only count rows from the rank table (rankSection), not the "Top 10
  // Competitors" table further down — otherwise both tables' rows are summed
  // and the keyword count is inflated.
  const tableLines = rankSection.split('\n').filter(l => l.startsWith('| ') && !l.startsWith('| Keyword') && !l.startsWith('|---'));
  let bbgPage1 = 0, bbgPage2 = 0, bbgMissing = 0;
  for (const line of tableLines) {
    const cols = line.split('|').map(c => c.trim());
    const bbgCol = cols[6]; // BBG is at index 6
    if (!bbgCol || bbgCol === '—' || bbgCol === '-' || bbgCol === '') bbgMissing++;
    else if (bbgCol.startsWith('**')) bbgPage1++;
    else if (!bbgCol.startsWith('*')) bbgPage1++;
    else bbgPage2++;
  }

  return {
    id: cid,
    isOverview: /overview/i.test(cid),
    title,
    meta,
    rankHtml: marked(rankSection),
    scoreHtml: marked(scoreSection),
    stats: { page1: bbgPage1, page2: bbgPage2, missing: bbgMissing, total: tableLines.length },
    history: historyByCluster.get(cid) ?? [],
  };
  });

  // "Keywords ranked in top 10" — derived from the already-parsed per-cluster
  // rank cells: page1 = bold (top 3) + plain (top 10). Summed across non-overview
  // groups so the card works off stored report data without a pipeline change.
  if (headline.length > 0) {
    const top10 = groups.reduce((s, g) => s + g.stats.page1, 0);
    const total = ind?.total ?? groups.reduce((s, g) => s + g.stats.total, 0);
    // Insert right after "Keywords ranked in top 100".
    headline.splice(1, 0, { label: 'Keywords ranked in top 10', value: `${top10}/${total}` });
  }

  return { groups, headline };
}

// Accent colours for the headline KPI cards (cycled in order).
const HEADLINE_COLORS = ['var(--bbg-blue)', '#16a34a', 'var(--bbg-gray-dark)', 'var(--bbg-red)'];

const byProject = await Promise.all(
  projects.map(async p => {
    const [reports, history] = await Promise.all([listReports(p.id), listKeywordHistory(p.id)]);
    return { ...p, ...buildGroups(reports, history) };
  }),
);
---
<Layout title="Competitors" scoped module="seo">
  <div class="mb-8">
    <a href="/" class="link-muted mb-4 inline-block">&larr; Dashboard</a>
    <h1 class="font-heading text-3xl font-bold tracking-tight mb-2" style="color: var(--bbg-red)">⚔️ Competitor Rankings</h1>
    <p class="text-muted-foreground">SERP rank tracking vs top 10 competitors per keyword group · <span data-active-project-name>this project</span></p>
    <SeoNav current="competitors" />
  </div>

  {byProject.map(p => {
    const groups = p.groups;
    const headline = p.headline;
    const canRefresh = p.id === 'chinawebfoundry';
    const HEADLINE_KEYS = ['ranked', 'rankedTop10', 'covered', 'index'];
    return (
    <div data-project-panel={p.id} class="hidden" data-competitors-panel data-project={p.id}>
  {headline.length > 0 ? (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-10">
      {headline.map((s, i) => (
        <div class="ui-card p-6 text-center flex flex-col items-center">
          <div class="text-3xl font-bold mb-2 tabular-nums" data-kpi={HEADLINE_KEYS[i]} style={`color: ${HEADLINE_COLORS[i % HEADLINE_COLORS.length]}`}>{s.value}</div>
          <div class="text-xs text-muted-foreground uppercase tracking-wide">{s.label}</div>
          {HEADLINE_KEYS[i] === 'rankedTop10' && (
            <button type="button" data-view-top10
              class="btn-outline text-xs py-1 px-3 mt-3 font-semibold"
              style="border-color: #16a34a; color: #16a34a"
              title="Open the clusters and highlight the keywords ranked in the top 10">
              View
            </button>
          )}
        </div>
      ))}
    </div>
  ) : groups.length > 0 && (
    <div class="grid grid-cols-3 gap-3 mb-10">
      {[
        { label: 'Groups tracked', value: groups.length, color: 'var(--bbg-blue)' },
        { label: 'Reports generated', value: groups.length, color: 'var(--bbg-gray-dark)' },
        { label: 'Keywords scored', value: groups.reduce((s, g) => s + g.stats.total, 0), color: 'var(--bbg-red)' },
      ].map(s => (
        <div class="ui-card p-5 text-center">
          <div class="text-2xl font-bold mb-1" style={`color: ${s.color}`}>{s.value}</div>
          <div class="text-xs text-muted-foreground uppercase tracking-wide">{s.label}</div>
        </div>
      ))}
    </div>
  )}

  {groups.length === 0 ? (
    <div class="ui-empty">
      <div class="mb-1">No competitor reports for <span class="font-semibold" style={`color: ${p.color}`}>{p.name}</span> yet.</div>
      <div class="text-xs">Run the SERP ranking script to populate the <code>serp_reports</code> table for this project.</div>
    </div>
  ) : (
    groups.map(g => (
      <details class="mb-6 ui-card overflow-hidden group" open={false} data-group data-cid={g.id}>
        <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none hover:bg-muted transition-colors" style="list-style: none">
          <div class="flex items-center gap-4">
            <span class="text-lg font-bold">{g.title}</span>
            <span data-count-badge class="text-xs font-semibold px-2 py-0.5 rounded-full bg-muted text-muted-foreground whitespace-nowrap">
              {g.stats.total} {g.stats.total === 1 ? 'keyword' : 'keywords'}
            </span>
            <span class="text-xs text-muted-foreground">{g.meta.split('|')[0]?.replace('Date:', '').trim()}</span>
          </div>
          <div class="flex items-center gap-3">
            {g.stats.page1 > 0 && (
              <span data-p1-badge class="text-xs font-semibold px-2 py-1 rounded-full text-white" style="background: var(--bbg-blue)">
                p1: {g.stats.page1}/{g.stats.total}
              </span>
            )}
            {g.stats.page1 === 0 && (
              <span data-p1-badge class="text-xs font-semibold px-2 py-1 rounded-full text-white" style="background: var(--bbg-gray-muted)">
                not on p1
              </span>
            )}
            {canRefresh && !g.isOverview && (
              <button type="button" data-refresh data-cid={g.id} title="Re-run live SERP ranking for this cluster"
                class="btn-outline text-xs py-1.5 font-semibold">
                <svg data-refresh-icon class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                Refresh
              </button>
            )}
            <svg class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </summary>

        <div class="border-t border-border">
          <!-- Live refresh progress (filled by competitorsRefresh.ts) -->
          <div data-refresh-zone class="hidden px-6 pt-5"></div>

          <!-- Refresh history: previous → current rank, per keyword -->
          {g.history.length > 0 && (
            <div data-history class="px-6 pt-5 pb-2">
              <h3 class="ui-eyebrow mb-3">Refresh History <span class="text-muted-foreground font-normal normal-case">· previous → current rank</span></h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1">
                {g.history.map(h => {
                  // Lower rank number is better: current < previous ⇒ improved (green).
                  const b = h.before_rank, a = h.after_rank;
                  const dir = b == null || a == null || a === b ? 0 : a < b ? 1 : -1;
                  const color = dir > 0 ? '#16a34a' : dir < 0 ? 'var(--bbg-red)' : 'var(--bbg-gray-muted)';
                  const fmt = (r: number | null) => (r == null ? '—' : `#${r}`);
                  return (
                    <div class="flex items-center gap-2 text-xs py-0.5">
                      <span class="text-gray-600 truncate">{h.keyword}</span>
                      <span class="ml-auto tabular-nums text-gray-400">{fmt(b)}</span>
                      <span style={`color: ${color}`}>→</span>
                      <span class="tabular-nums font-semibold" style={`color: ${color}`}>{fmt(a)}</span>
                    </div>
                  );
                })}
              </div>
            </div>
          )}

          <!-- Rank table: horizontally scrollable -->
          <div class="px-6 pt-5 pb-2">
            <h3 class="ui-eyebrow mb-3">Keyword Rankings</h3>
            <div class="overflow-x-auto rounded-xl border border-border">
              <div data-rank-table class="rank-table prose max-w-none" set:html={g.rankHtml} />
            </div>
          </div>

          <!-- Visibility scores -->
          <div class="px-6 pb-6 pt-2">
            <h3 class="ui-eyebrow mb-3">Top 10 Competitors (auto-discovered)</h3>
            <div class="overflow-x-auto rounded-xl border border-border">
              <div data-score-table class="prose max-w-none" set:html={g.scoreHtml} />
            </div>
          </div>
        </div>
      </details>
    ))
  )}
    </div>
    );
  })}
</Layout>

<script>
  import { mountCompetitorsRefresh } from '../../scripts/competitorsRefresh';
  mountCompetitorsRefresh();
</script>

<style>
  /* Rank colour coding */
  .rank-table :global(td) { white-space: nowrap; }
  .rank-table :global(strong) { color: #16a34a; font-weight: 700; } /* top 3 = green */

  /* Click a row to toggle a selection colour */
  .rank-table :global(tbody tr) { cursor: pointer; transition: background-color 0.12s; }
  .rank-table :global(tbody tr:hover) { background: rgba(6, 147, 227, 0.06); }
  .rank-table :global(tbody tr.rank-row-selected) { background: rgba(6, 147, 227, 0.16) !important; }

  details summary::-webkit-details-marker { display: none; }
</style>
