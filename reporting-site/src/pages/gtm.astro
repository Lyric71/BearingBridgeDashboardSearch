---
import Layout from '../layouts/Layout.astro';
---
<Layout title="GTM Kanban" module="kanban">
  <div class="mb-8">
    <a href="/" class="link-muted mb-4 inline-block">&larr; Dashboard</a>
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <h1 class="font-heading text-3xl font-bold tracking-tight mb-2">Go-To-Market Kanban</h1>
        <p class="text-muted-foreground text-sm">Add, edit, delete &amp; drag tasks · right-click a task for move &amp; duplicate — changes save in this browser · manage projects on the <a href="/projects" class="underline hover:text-foreground">Projects</a> page</p>
      </div>
      <button data-kanban-reset class="btn-outline text-xs py-1.5">
        Reset to plan
      </button>
    </div>
  </div>

  <!-- Project panels are rendered client-side from the project store. -->
  <div id="project-board"></div>
</Layout>

<script>
  import { mountProjectBoard } from '../scripts/projectBoard';
  mountProjectBoard();
</script>
