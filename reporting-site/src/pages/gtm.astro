---
import Layout from '../layouts/Layout.astro';
---
<Layout title="GTM Kanban" module="kanban">
  <div class="mb-8">
    <a href="/" class="text-sm text-gray-400 hover:text-gray-600 mb-4 inline-block">&larr; Dashboard</a>
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <h1 class="text-3xl font-bold mb-2" style="color: var(--bbg-gray-dark)">Go-To-Market Kanban</h1>
        <p class="text-gray-400 text-sm">Add, edit, delete &amp; drag tasks · right-click a task for move &amp; duplicate — changes save in this browser · manage projects on the <a href="/projects" class="underline hover:text-gray-600">Projects</a> page</p>
      </div>
      <button data-kanban-reset class="text-xs px-3 py-1.5 rounded-lg border border-gray-200 text-gray-500 hover:border-gray-400 hover:text-gray-700 transition-colors">
        Reset to plan
      </button>
    </div>
  </div>

  <!-- Project panels are rendered client-side from the project store. -->
  <div id="project-board"></div>
</Layout>

<script>
  import { mountProjectBoard } from '../scripts/projectBoard';
  mountProjectBoard();
</script>
