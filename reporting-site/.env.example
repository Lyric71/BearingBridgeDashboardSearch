# Login page credentials. Copy to .env and set real values.
# On Vercel, set these in Project Settings → Environment Variables.
SITE_LOGIN=
SITE_PASSWORD=

# --- Supabase (single source of truth) ---
# From Supabase dashboard → Project Settings → API keys.
# SUPABASE_KEY is the publishable key (safe to expose, client-side reads).
# SUPABASE_SECRET_KEY is the secret key (SERVER-ONLY: writes, importer, bypasses RLS).
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SECRET_KEY=

# Optional — Postgres connection string for raw SQL (psql).
# Use the *pooler* (transaction mode, port 6543). Settings → Database → Connection string.
DATABASE_URL=
